# Stage 1: Build the Dashboard React application
FROM node:current-alpine3.23 AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run dashboard:build

# Stage 2: Serve with nginx
FROM dhi.io/nginx:1

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf.dashboard /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["-g", "daemon off;"]